# Variables de entorno necesarias para FleetAdmin Pro
# Copiá este archivo como .env y completá con tus valores reales

GEMINI_API_KEY=AIzaSy...tu_clave_aqui

# Firebase (JSON completo en base64)
FIREBASE_SERVICE_ACCOUNT=...

# OpenAI Whisper (opcional, para transcripción de audios)
OPENAI_API_KEY=sk-...tu_clave_aqui

# ElevenLabs — Voz Premium KITT (El Auto Fantástico)
# Crear cuenta gratis en https://elevenlabs.io y copiar tu API Key
ELEVENLABS_API_KEY=...tu_clave_aqui
# Voice ID: Buscar "KITT" en la librería pública de ElevenLabs y copiar el ID
ELEVENLABS_VOICE_ID=...id_de_voz_kitt
